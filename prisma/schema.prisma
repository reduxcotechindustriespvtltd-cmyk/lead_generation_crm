// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  SALES_EXECUTIVE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SALES_EXECUTIVE)
  phone        String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens             RefreshToken[]
  assignedLeads             Lead[]                 @relation("LeadAssignee")
  createdLeads              Lead[]                 @relation("LeadCreatedBy")
  notes                     Note[]
  activities                Activity[]
  followUps                 FollowUp[]             @relation("FollowUpCreatedBy")
  completedFollowUps        FollowUp[]             @relation("FollowUpCompletedBy")
  auditLogs                 AuditLog[]
  notifications             Notification[]
  connectedMetaAccounts     MetaAccount[]
  connectedWhatsAppAccounts WhatsAppAccount[]
  assignmentRuleMembers     AssignmentRuleMember[]
  sentWhatsAppMessages      WhatsAppMessage[]

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// Meta (Facebook/Instagram) connected accounts
// ─────────────────────────────────────────────────────────────

enum MetaAccountType {
  FACEBOOK_PAGE
  INSTAGRAM_ACCOUNT
}

model MetaAccount {
  id                  String          @id @default(cuid())
  type                MetaAccountType
  metaPageId          String          @unique
  name                String
  instagramBusinessId String?
  accessToken         String // encrypted at rest by app layer
  tokenExpiresAt      DateTime?
  isActive            Boolean         @default(true)
  connectedById       String?
  lastSyncedAt        DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  connectedBy User?      @relation(fields: [connectedById], references: [id], onDelete: SetNull)
  campaigns   Campaign[]
  leadForms   LeadForm[]

  @@map("meta_accounts")
}

enum WhatsAppConnectionMethod {
  MANUAL_TOKEN
  EMBEDDED_SIGNUP
}

// A WhatsApp Business Platform (Cloud API) phone number — distinct from
// MetaAccount because click-to-WhatsApp leads have no Lead Ads form data;
// they only ever exist as inbound WhatsApp messages.
model WhatsAppAccount {
  id                 String                   @id @default(cuid())
  phoneNumberId      String                   @unique
  wabaId             String
  businessId         String?
  displayPhoneNumber String
  displayName        String?
  qualityRating      String?
  accessToken        String // encrypted at rest by app layer
  tokenExpiresAt     DateTime?
  connectedVia       WhatsAppConnectionMethod @default(MANUAL_TOKEN)
  isActive           Boolean                  @default(true)
  connectedById      String?
  lastMessageAt      DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  connectedBy User? @relation(fields: [connectedById], references: [id], onDelete: SetNull)
  messages    WhatsAppMessage[]

  @@index([wabaId])
  @@map("whatsapp_accounts")
}

// ─────────────────────────────────────────────────────────────
// WhatsApp message thread (per lead)
// ─────────────────────────────────────────────────────────────

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  RECEIVED
  SENT
  FAILED
}

model WhatsAppMessage {
  id                String                   @id @default(cuid())
  leadId            String
  whatsAppAccountId String
  direction         WhatsAppMessageDirection
  content           String
  messageType       String                   @default("text")
  status            WhatsAppMessageStatus    @default(RECEIVED)
  errorMessage      String?
  whatsAppMessageId String?                  @unique
  sentById          String?
  createdAt         DateTime                 @default(now())

  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount @relation(fields: [whatsAppAccountId], references: [id])
  sentBy          User?           @relation(fields: [sentById], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([whatsAppAccountId])
  @@map("whatsapp_messages")
}

// ─────────────────────────────────────────────────────────────
// Meta ad hierarchy (normalized, synced from Meta Graph API)
// ─────────────────────────────────────────────────────────────

model Campaign {
  id             String   @id @default(cuid())
  metaCampaignId String   @unique
  metaAccountId  String
  name           String
  objective      String?
  status         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  metaAccount MetaAccount @relation(fields: [metaAccountId], references: [id], onDelete: Cascade)
  adSets      AdSet[]
  leads       Lead[]

  @@index([metaAccountId])
  @@map("campaigns")
}

model AdSet {
  id          String   @id @default(cuid())
  metaAdSetId String   @unique
  campaignId  String
  name        String
  status      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads      Ad[]
  leads    Lead[]

  @@index([campaignId])
  @@map("ad_sets")
}

model Ad {
  id        String   @id @default(cuid())
  metaAdId  String   @unique
  adSetId   String
  name      String
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adSet AdSet  @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@index([adSetId])
  @@map("ads")
}

model LeadForm {
  id            String   @id @default(cuid())
  metaFormId    String   @unique
  metaAccountId String
  name          String
  status        String?
  questions     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  metaAccount MetaAccount @relation(fields: [metaAccountId], references: [id], onDelete: Cascade)
  leads       Lead[]

  @@index([metaAccountId])
  @@map("lead_forms")
}

// ─────────────────────────────────────────────────────────────
// Lead status (configurable, not hardcoded)
// ─────────────────────────────────────────────────────────────

model LeadStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  isFinal   Boolean  @default(false) // e.g. Converted, Lost, Spam
  isWon     Boolean  @default(false) // e.g. Converted (for conversion-rate math)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads Lead[]

  @@map("lead_statuses")
}

// ─────────────────────────────────────────────────────────────
// Leads
// ─────────────────────────────────────────────────────────────

enum LeadSource {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  MANUAL
  WEBSITE
  OTHER
}

model Lead {
  id String @id @default(cuid())

  // Core contact info
  fullName String
  phone    String
  email    String?
  city     String?
  state    String?

  // Meta attribution — normalized FKs (nullable: manual leads have none)
  campaignId String?
  adSetId    String?
  adId       String?
  formId     String?

  // Denormalized snapshot of attribution at capture time.
  // Meta campaign/ad names can be renamed or deleted later; the lead
  // must keep showing what it was attributed to when it came in.
  campaignName String?
  adName       String?
  adSetName    String?
  formName     String?

  source     LeadSource @default(MANUAL)
  metaLeadId String?    @unique // Meta's leadgen_id, used for dedup
  rawPayload Json? // full original payload from Meta webhook/API

  statusId      String
  assignedToId  String?
  createdById   String?
  followUpDate  DateTime?
  isDuplicate   Boolean   @default(false)
  duplicateOfId String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActivityAt DateTime @default(now())

  campaign    Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  adSet       AdSet?     @relation(fields: [adSetId], references: [id], onDelete: SetNull)
  ad          Ad?        @relation(fields: [adId], references: [id], onDelete: SetNull)
  form        LeadForm?  @relation(fields: [formId], references: [id], onDelete: SetNull)
  status      LeadStatus @relation(fields: [statusId], references: [id])
  assignedTo  User?      @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy   User?      @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  duplicateOf Lead?      @relation("LeadDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates  Lead[]     @relation("LeadDuplicates")

  notes            Note[]
  activities       Activity[]
  followUps        FollowUp[]
  whatsAppMessages WhatsAppMessage[]

  @@index([statusId])
  @@index([assignedToId])
  @@index([source])
  @@index([campaignId])
  @@index([createdAt])
  @@index([phone])
  @@map("leads")
}

// ─────────────────────────────────────────────────────────────
// Activity timeline (full audit trail per lead)
// ─────────────────────────────────────────────────────────────

enum ActivityType {
  LEAD_CREATED
  ASSIGNED
  REASSIGNED
  STATUS_CHANGED
  CALLED
  NOTE_ADDED
  FOLLOW_UP_SCHEDULED
  FOLLOW_UP_COMPLETED
  FOLLOW_UP_MISSED
  EMAIL_SENT
  WHATSAPP_SENT
  WHATSAPP_REPLIED
  CONVERTED
  MARKED_LOST
  MARKED_SPAM
  MARKED_DUPLICATE
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String
  userId      String? // null = system-generated (e.g. webhook sync)
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([createdAt])
  @@map("activities")
}

// ─────────────────────────────────────────────────────────────
// Notes (with @mentions)
// ─────────────────────────────────────────────────────────────

model Note {
  id               String   @id @default(cuid())
  leadId           String
  userId           String
  content          String
  mentionedUserIds String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("notes")
}

// ─────────────────────────────────────────────────────────────
// Follow-ups
// ─────────────────────────────────────────────────────────────

enum FollowUpStatus {
  PENDING
  DONE
  MISSED
  CANCELLED
}

model FollowUp {
  id            String         @id @default(cuid())
  leadId        String
  dueAt         DateTime
  note          String?
  status        FollowUpStatus @default(PENDING)
  createdById   String
  completedById String?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  lead        Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy   User  @relation("FollowUpCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  completedBy User? @relation("FollowUpCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([dueAt])
  @@index([status])
  @@map("follow_ups")
}

// ─────────────────────────────────────────────────────────────
// Assignment rules (round robin / bulk)
// ─────────────────────────────────────────────────────────────

enum AssignmentMethod {
  MANUAL
  ROUND_ROBIN
  BULK
}

model AssignmentRule {
  id                String           @id @default(cuid())
  name              String
  method            AssignmentMethod @default(ROUND_ROBIN)
  isActive          Boolean          @default(true)
  lastAssignedIndex Int              @default(-1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  members AssignmentRuleMember[]

  @@map("assignment_rules")
}

model AssignmentRuleMember {
  id     String @id @default(cuid())
  ruleId String
  userId String
  order  Int    @default(0)

  rule AssignmentRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ruleId, userId])
  @@map("assignment_rule_members")
}

// ─────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────

enum NotificationType {
  LEAD_ASSIGNED
  FOLLOW_UP_DUE
  FOLLOW_UP_MISSED
  MENTION
  LEAD_STATUS_CHANGED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// Audit log (system-wide, security-relevant actions)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// White-label branding — a single row per deployed instance.
// Each client gets their own isolated instance, so this is a
// singleton rather than per-tenant, unlike everything else here.
// ─────────────────────────────────────────────────────────────

model OrgSettings {
  id             String   @id @default("singleton")
  name           String   @default("CRM")
  logoUrl        String?
  primaryColor   String   @default("#c2410c")
  secondaryColor String   @default("#0d9488")
  supportEmail   String?
  updatedAt      DateTime @updatedAt

  @@map("org_settings")
}
